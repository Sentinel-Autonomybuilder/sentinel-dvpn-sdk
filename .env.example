# Sentinel dVPN SDK Configuration
# Copy this file to .env and fill in your values

# Your wallet mnemonic (12 or 24 words)
# Generate programmatically: const { mnemonic } = await generateWallet();
# Or use: https://iancoleman.io/bip39/ (select "12 words", coin "ATOM")
# Fund it: buy P2P on an exchange and send to your sent1... address
MNEMONIC=your twelve word mnemonic phrase goes here replace me

# Chain endpoints (defaults work, change only if primary is down)
RPC=https://rpc.sentinel.co:443
LCD=https://lcd.sentinel.co

# Path to V2Ray binary (auto-detected if not set)
# V2RAY_PATH=./bin/v2ray.exe   # Windows
# V2RAY_PATH=./bin/v2ray       # Linux/macOS

# Optional: rarely need changing (SDK has sensible defaults)
# DENOM=udvpn
# GAS_PRICE=0.2udvpn
