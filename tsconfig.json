{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationDir": "./types",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "sentinel-dvpn-sdk": ["./types/index.d.ts"]
    }
  },
  "include": [
    "*.js",
    "chain/**/*.js",
    "connection/**/*.js",
    "protocol/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "test",
    "examples",
    "bin"
  ]
}
